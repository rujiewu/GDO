# LMMS evaluation example for the paper benchmarks.

CKPT_PATH=/path/to/checkpoint_or_run_directory
OUTPUT_ROOT=outputs/eval

TASKS=mvbench,videomme,mlvu_test,lvbench
CKPT_STEPS=

MAX_NUM_FRAMES=32
MAX_PIXELS=602112
FPS=1
BATCH_SIZE=1

NPROC_PER_NODE=8
NNODES=1
NODE_RANK=0
MASTER_ADDR=127.0.0.1
MASTER_PORT=29501
