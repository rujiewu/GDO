# One-epoch Qwen3-VL-8B-Instruct SFT example.

MODEL_PATH=/path/to/Qwen3-VL-8B-Instruct
DATA_PATH=/path/to/train.jsonl
OUTPUT_DIR=outputs/train/qwen3_vl_8b_instruct

TRAIN_TYPE=full
DEEPSPEED_STAGE=zero2
FREEZE_VIT=false
FREEZE_ALIGNER=false
FREEZE_LLM=false

NPROC_PER_NODE=8
NNODES=1
NODE_RANK=0
MASTER_ADDR=127.0.0.1
MASTER_PORT=29500

PER_DEVICE_TRAIN_BATCH_SIZE=1
PER_DEVICE_EVAL_BATCH_SIZE=1
GRADIENT_ACCUMULATION_STEPS=1
MAX_LENGTH=8192
MAX_STEPS=-1

LEARNING_RATE=2e-5
SAVE_STEPS=20
EVAL_STEPS=20
AUTO_SET_SAVE_EVAL_STEPS=1
AUTO_INTERVAL_FRACTION=5
LOGGING_STEPS=5
SAVE_TOTAL_LIMIT=-1

SPLIT_DATASET_RATIO=0.001
DATASET_NUM_PROC=8
DATALOADER_NUM_WORKERS=8
STRICT_MODE=false
REPORT_TO=none

VIDEO_MAX_PIXELS=50176
IMAGE_MAX_PIXELS=50176
MAX_PIXELS=50176
